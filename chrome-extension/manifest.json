{
  "manifest_version": 3,
  "name": "Save to GitHub Notes",
  "version": "1.0",
  "description": "Right-click selected text to save it as a Markdown note in GitHub",
  "permissions": ["contextMenus", "storage", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}